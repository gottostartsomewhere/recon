# ── Recon configuration ──────────────────────────────────────────────
# Copy this file to ".env" and paste in your two FREE keys (no credit card).
# Without keys, Recon still runs in DEMO mode (a scripted sample dossier).

# Groq — free LLM inference.  Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Tavily — free web search (1,000 searches/mo).  Get a key: https://app.tavily.com
TAVILY_API_KEY=

# Optional overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# PORT=8787
